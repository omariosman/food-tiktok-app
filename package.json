{
  "name": "food-tiktok-app",
  "version": "1.0.0",
  "description": "Food TikTok App - Monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "mobile",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix mobile && npm install --prefix shared",
    "build:shared": "npm run build --prefix shared",
    "build:backend": "npm run build --prefix backend",
    "build:all": "npm run build:shared && npm run build:backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:mobile": "npm run start --prefix mobile",
    "test:backend": "npm run test --prefix backend",
    "test:mobile": "npm run test --prefix mobile",
    "lint:backend": "npm run lint --prefix backend",
    "clean": "rm -rf node_modules backend/node_modules mobile/node_modules shared/node_modules backend/dist shared/dist"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "food",
    "delivery",
    "react-native",
    "nodejs",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "jimp": "^1.6.0"
  }
}
